# Fire Detection - YOLOv9 Environment Configuration
# ===================================================
# Copy file ini ke .env dan sesuaikan dengan kebutuhan Anda

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False
RELOAD=False

# Model Configuration
MODEL_PATH=yolov9c.pt
MODEL_CONF_THRESHOLD=0.25
MODEL_IOU_THRESHOLD=0.45
MODEL_MAX_DET=300

# Dataset Configuration
DATASET_PATH=FIRE DETECTION USING YOLOV9/DATASET

# Upload Configuration
MAX_UPLOAD_SIZE=10485760  # 10 MB in bytes
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp,bmp

# API Configuration
API_TITLE=Fire Detection - YOLOv9
API_VERSION=1.0.0
API_DESCRIPTION=Aplikasi deteksi kebakaran menggunakan YOLOv9

# CORS Configuration (untuk production)
CORS_ORIGINS=*
CORS_METHODS=*
CORS_HEADERS=*

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=app.log

# Performance Configuration
WORKERS=1
GPU_ENABLED=True
BATCH_SIZE=1

# Cache Configuration
ENABLE_CACHE=False
CACHE_TTL=3600  # seconds

# Security (untuk production)
SECRET_KEY=your-secret-key-here-change-in-production
API_KEY_ENABLED=False
API_KEY=your-api-key-here

# Email Alert (optional)
EMAIL_ENABLED=False
EMAIL_FROM=alert@firedetection.com
EMAIL_TO=admin@example.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-password

# Webhook (optional)
WEBHOOK_ENABLED=False
WEBHOOK_URL=https://your-webhook-url.com/alert
